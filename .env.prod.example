# Ambiente de PRODUÇÃO -- copie para `.env.prod` neste mesmo diretório e troque as senhas
# (valores DIFERENTES dos de `.env.test`, nunca reaproveite). Suba com:
# docker compose --env-file .env.prod -p bitin-prod up -d
# Nome de projeto ("bitin-prod") isola volumes/rede desta stack da de teste.

ENVIRONMENT=production
SECRET_KEY=troque-por-um-valor-real-de-producao-diferente-do-de-teste

POSTGRES_USER=bitin
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=bitin

MONGO_INITDB_ROOT_USERNAME=bitin
MONGO_INITDB_ROOT_PASSWORD=troque-esta-senha
MONGO_DB_NAME=bitin_db

# Porta onde o navegador acessa o sistema de PRODUÇÃO neste host.
WEB_PORT=80
# Portas dos bancos/API só pra debug local (127.0.0.1).
API_PORT=8000
POSTGRES_PORT=5432
MONGO_PORT=27017

# Troque pela URL de verdade de onde o frontend de PRODUÇÃO fica acessível (ex.:
# http://bitin.empresa.local) -- sem isso, o navegador bloqueia toda chamada à API por CORS.
CORS_ORIGINS=http://localhost
