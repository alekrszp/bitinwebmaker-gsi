# Ambiente de TESTE (staging) -- copie para `.env.test` neste mesmo diretório e troque as
# senhas. Suba com: docker compose --env-file .env.test -p bitin-test up -d
# Nome de projeto ("bitin-test") isola volumes/rede desta stack da de produção -- pode rodar
# as duas ao mesmo tempo no mesmo host, cada uma com sua porta própria (valores abaixo já são
# diferentes dos de produção de propósito).

# ENVIRONMENT=production aqui é de propósito, mesmo sendo a stack de TESTE -- é o único valor
# que o backend reconhece pra ligar a checagem de segurança "SECRET_KEY não pode ser o
# default" (backend/main.py::lifespan); não existe hoje uma diferenciação funcional real entre
# teste/produção no código, só infraestrutura separada (bancos/portas próprios). Deixar como
# "development" desligaria essa checagem também no ambiente de teste.
ENVIRONMENT=production
SECRET_KEY=troque-por-um-valor-real-de-teste

POSTGRES_USER=bitin_test
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=bitin_test

MONGO_INITDB_ROOT_USERNAME=bitin_test
MONGO_INITDB_ROOT_PASSWORD=troque-esta-senha
MONGO_DB_NAME=bitin_test_db

# Porta onde o navegador acessa o sistema de TESTE neste host.
WEB_PORT=8081
# Portas dos bancos/API só pra debug local (127.0.0.1) -- diferentes das de produção pra não
# colidir se as duas stacks rodarem no mesmo host.
API_PORT=8001
POSTGRES_PORT=5433
MONGO_PORT=27018

# Troque pela URL de verdade de onde o frontend de TESTE fica acessível (ex.:
# http://10.0.0.5:8081 ou http://bitin-teste.empresa.local) -- sem isso, o navegador bloqueia
# toda chamada à API por CORS.
CORS_ORIGINS=http://localhost:8081
